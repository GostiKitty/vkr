{
  "name": "desktop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n ui,engine,electron -c blue,green,magenta \"npm:dev:ui\" \"npm:dev:engine\" \"npm:dev:electron\"",
    "dev:ui": "vite",
    "dev:engine": "cd ../../engine && python -m uvicorn app:app --host 127.0.0.1 --port 8010 --reload",
    "dev:electron": "wait-on http://127.0.0.1:5173 && electron electron/main.cjs",
    "dev:stop": "powershell -NoProfile -Command \"@(5173,8010) | ForEach-Object { Get-NetTCPConnection -LocalPort $_ -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue } }\"",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npx tsc -p tsconfig.tests.json && node --loader ./tests/esm-resolver.mjs tests-dist/tests/run-tests.js"
  },
  "dependencies": {
    "jspdf": "^4.2.0",
    "katex": "^0.16.33",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-katex": "^3.1.0",
    "recharts": "^2.12.2",
    "three": "^0.169.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
